{
  "name": "jest-circleci-coverage",
  "version": "0.1.3",
  "description": "A Jest plugin that generates coverage data for CircleCI's Smarter Testing.",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./environment": "./src/environment-node.ts",
    "./enrironment-node": "./src/environment-node.ts",
    "./environment-jsdom": "./src/environment-jsdom.ts",
    "./reporter": "./src/reporter.ts"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "oxlint --quiet",
    "format": "prettier . --check",
    "generate": "circleci run testsuite 'integration test' --local --test-analysis=all && cat coverage.json | jq --sort-keys > coveragetmp.json && mv coveragetmp.json coverage.json",
    "generate:ci": "circleci run testsuite 'integration test' --test-analysis=all && cat coverage.json | jq --sort-keys > coveragetmp.json && mv coveragetmp.json coverage.json"
  },
  "peerDependencies": {
    "jest": ">=30.0.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@jest/environment": "^30.2.0",
    "@jest/reporters": "^30.2.0",
    "@jest/types": "^30.2.0",
    "@prettier/plugin-oxc": "^0.1.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jest-junit": "^16.0.0",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "jest-environment-node": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "@circleci/v8-coverage-collector": "npm:@jsr/circleci__v8-coverage-collector@0.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
